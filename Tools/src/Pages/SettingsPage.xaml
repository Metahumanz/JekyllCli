<Page x:Class="BlogTools.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:BlogTools.Helpers"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Title="{DynamicResource NavSettings}">
    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8" />
                    <ThicknessAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Margin" From="0,40,0,0" To="16" Duration="0:0:0.8">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>
    <Grid Margin="16" x:Name="MainContent" Opacity="0" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <ui:SymbolIcon Symbol="Globe24" FontSize="32" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
            <StackPanel>
                <TextBlock Text="{DynamicResource SettingsTitle}" FontSize="24" FontWeight="SemiBold"/>
                <TextBlock Text="{DynamicResource SettingsSub}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <ui:InfoBar Grid.Row="1" x:Name="StatusInfo" IsOpen="False" Message="" Severity="Success" Margin="0,0,0,8" />

        <ScrollViewer Grid.Row="2" x:Name="PageScrollViewer" VerticalScrollBarVisibility="Auto" Background="Transparent" Focusable="False" 
                      PreviewMouseWheel="PageScrollViewer_PreviewMouseWheel"
                      helpers:SmoothScrollHelper.SmoothingEnabled="True">
            <StackPanel Background="Transparent" Margin="0,0,16,0">

                <!-- ═══ 第三组：站点信息 ═══ -->
                <TextBlock Text="{DynamicResource SettingsSecSiteInfo}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource AppCardCornerRadius}" Padding="20" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Title -->
                        <TextBlock Text="{DynamicResource SettingsLabelSiteTitle}" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        <ui:TextBox x:Name="TitleBox" Grid.Row="0" Grid.Column="2" Margin="0,0,0,12" PlaceholderText="{DynamicResource SettingsLabelSiteTitle}"/>

                        <!-- Tagline -->
                        <TextBlock Text="{DynamicResource SettingsLabelTagline}" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        <ui:TextBox x:Name="TaglineBox" Grid.Row="1" Grid.Column="2" Margin="0,0,0,12" PlaceholderText="{DynamicResource SettingsLabelTagline}"/>

                        <!-- URL -->
                        <TextBlock Text="{DynamicResource SettingsLabelUrl}" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        <ui:TextBox x:Name="UrlBox" Grid.Row="2" Grid.Column="2" Margin="0,0,0,12" PlaceholderText="https://example.com"/>

                        <!-- Description -->
                        <TextBlock Text="{DynamicResource SettingsLabelDescription}" VerticalAlignment="Top" Grid.Row="3" Grid.Column="0" Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        <ui:TextBox x:Name="DescriptionBox" Grid.Row="3" Grid.Column="2" AcceptsReturn="True" MinHeight="72" TextWrapping="Wrap"
                                    PlaceholderText="{DynamicResource SettingsLabelDescription}"/>
                    </Grid>
                </Border>

                <TextBlock Text="{DynamicResource SettingsSecAuthor}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <!-- removed InfoBar -->
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource AppCardCornerRadius}" Padding="20" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Name / Email -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource SettingsLabelAuthorName}" FontSize="13" Margin="0,0,0,6" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBox x:Name="AuthorNameBox" PlaceholderText="Your Name"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource SettingsLabelEmail}" FontSize="13" Margin="0,0,0,6" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBox x:Name="EmailBox" PlaceholderText="name@example.com"/>
                        </StackPanel>

                        <!-- Row 1: GitHub / Bilibili -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource SettingsLabelGithub}" FontSize="13" Margin="0,0,0,6" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBox x:Name="GithubBox" PlaceholderText="octocat"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource SettingsLabelBilibili}" FontSize="13" Margin="0,0,0,6" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBox x:Name="BilibiliBox" PlaceholderText="https://space.bilibili.com/..."/>
                        </StackPanel>

                        <!-- Row 2: Avatar (full width) -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="{DynamicResource SettingsLabelAvatar}" FontSize="13" Margin="0,0,0,6" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBox x:Name="AvatarBox" PlaceholderText="/assets/img/avatar.png"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ 导航与选项卡 ═══ -->
                <TextBlock Text="{DynamicResource SettingsSecNav}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource AppCardCornerRadius}" Padding="16" Margin="0,0,0,24">
                    <StackPanel>
                        <Expander Header="{DynamicResource SettingsLabelAbout}" Margin="0,0,0,10">
                            <StackPanel Margin="10">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="{DynamicResource SettingsLabelSubTitle}" />
                                        <ui:TextBox x:Name="AboutTitleBox" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                        <TextBlock Text="{DynamicResource SettingsLabelSubIcon}" />
                                        <ui:TextBox x:Name="AboutIconBox" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{DynamicResource SettingsLabelSubOrder}" />
                                        <ui:TextBox x:Name="AboutOrderBox" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{DynamicResource SettingsLabelIntro}" Margin="0,10,0,5" />
                                <ui:TextBox x:Name="AboutContentBox" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="100" />
                            </StackPanel>
                        </Expander>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Archives -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="{DynamicResource SettingsLabelArchives}" FontSize="12" Margin="0,0,0,4"/>
                                <ui:TextBox x:Name="ArchivesTitleBox" Margin="0,0,0,5" />
                                <TextBlock Text="{DynamicResource SettingsLabelSubOrder}" FontSize="12" Margin="0,0,0,4"/>
                                <ui:TextBox x:Name="ArchivesOrderBox" />
                            </StackPanel>
                            <!-- Categories -->
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="{DynamicResource SettingsLabelCategories}" FontSize="12" Margin="0,0,0,4"/>
                                <ui:TextBox x:Name="CategoriesTitleBox" Margin="0,0,0,5"/>
                                <TextBlock Text="{DynamicResource SettingsLabelSubOrder}" FontSize="12" Margin="0,0,0,4"/>
                                <ui:TextBox x:Name="CategoriesOrderBox" />
                            </StackPanel>
                            <!-- Tags -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource SettingsLabelTags}" FontSize="12" Margin="0,0,0,4"/>
                                <ui:TextBox x:Name="TagsTitleBox" Margin="0,0,0,5" />
                                <TextBlock Text="{DynamicResource SettingsLabelSubOrder}" FontSize="12" Margin="0,0,0,4"/>
                                <ui:TextBox x:Name="TagsOrderBox" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══ 静态资源管理 ═══ -->
                <TextBlock Text="{DynamicResource SettingsSecAssets}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <StackPanel Margin="0,0,0,24">
                    <!-- ⚠️ v7.4.0+ 变更提示 -->
                    <ui:InfoBar IsOpen="True" IsClosable="False" Severity="Warning" Margin="0,0,0,8"
                                Title="{DynamicResource SettingsFaviconWarningTitle}"
                                Message="{DynamicResource SettingsFaviconWarningMsg}"/>

                    <ui:CardAction Margin="0,0,0,4" Icon="{ui:SymbolIcon Symbol=Globe24}" Click="OpenFaviconGenerator_Click">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource SettingsLabelFaviconGen}" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="{DynamicResource SettingsDescFaviconGen}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                    </ui:CardAction>

                    <ui:CardControl Margin="0,0,0,0" Icon="{ui:SymbolIcon Symbol=Image24}" Style="{StaticResource RoundedCardControlStyle}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsLabelFaviconUpload}" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="{DynamicResource SettingsDescFaviconUpload}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ui:Button Content="{DynamicResource SettingsBtnUpload}" Style="{StaticResource LiftedUiButtonStyle}" Click="UploadFavicons_Click" />
                    </ui:CardControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部操作栏 -->
        <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" Padding="0,12,0,0" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <ui:Button Content="{DynamicResource SettingsBtnSave}" Style="{StaticResource LiftedUiButtonStyle}" Click="SaveSettings_Click" Icon="{ui:SymbolIcon Symbol=Save24}" Margin="0,0,12,0" Padding="16,8"/>
                    <ui:Button Content="{DynamicResource SettingsBtnPublish}" Style="{StaticResource LiftedUiButtonStyle}" Appearance="Primary" Click="PublishButton_Click" Icon="{ui:SymbolIcon Symbol=Send24}" Padding="16,8"/>
                </StackPanel>
                <TextBlock VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                           Text="{DynamicResource SettingsRecommendActions}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
