<Page x:Class="BlogTools.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Title="仪表盘">
    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8" />
                    <ThicknessAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Margin" From="0,40,0,0" To="16" Duration="0:0:0.8">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>
    
    <Grid Margin="16" x:Name="MainContent" Opacity="0" Background="Transparent">
        <ScrollViewer x:Name="PageScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      Background="Transparent"
                      PreviewMouseWheel="PageScrollViewer_PreviewMouseWheel">
            <StackPanel Background="Transparent" Margin="0,0,16,0">
                
                <!-- 欢迎头部 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <ui:SymbolIcon Symbol="Home24" FontSize="36" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                    <StackPanel>
                        <TextBlock x:Name="WelcomeTitleText" Text="{DynamicResource DashboardWelcomeTitle}" FontSize="28" FontWeight="SemiBold"/>
                        <TextBlock x:Name="WelcomeSubText" Text="{DynamicResource DashboardWelcomeSub}" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- ═══ Chirpy 升级引导公告 ═══ -->
                <ui:CardExpander Margin="0,0,0,24" IsExpanded="False"
                                 ContentPadding="20">
                    <ui:CardExpander.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Megaphone24" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"
                                          Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource DashboardChirpyUpgradeTitle}" FontWeight="SemiBold" FontSize="15"/>
                                <TextBlock Text="{DynamicResource DashboardChirpyUpgradeSub}" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </ui:CardExpander.Header>

                    <StackPanel>
                        <!-- ⚠️ Favicon 重大调整 -->
                        <Border Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                CornerRadius="6" Padding="14" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6">
                                    <Run Text="{DynamicResource DashboardFaviconImportant}"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,10" Text="{DynamicResource DashboardFaviconDesc}">
                                </TextBlock>
                                <WrapPanel>
                                    <ui:Button Content="{DynamicResource DashboardBtnFaviconSettings}" Appearance="Primary" Style="{StaticResource LiftedUiButtonStyle}"
                                               Icon="{ui:SymbolIcon Symbol=Settings24}"
                                               Click="GoToSettingsForFavicon_Click" Margin="0,0,8,0" Padding="12,6"/>
                                    <ui:Button Content="{DynamicResource DashboardBtnOpenFaviconGenerator}" Style="{StaticResource LiftedUiButtonStyle}"
                                               Icon="{ui:SymbolIcon Symbol=Globe24}"
                                               Click="OpenFaviconGenerator_Click" Padding="12,6"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{DynamicResource DashboardFeatureTitle}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <StackPanel Margin="8,0,0,16">
                            <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="🎵" FontWeight="SemiBold"/> <Run Text="Spotify 播放器嵌入 (v7.4.0)"/> — 在 Markdown 中直接嵌入 Spotify 音乐或播客卡片。
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="🌐" FontWeight="SemiBold"/> <Run Text="Fediverse 联邦支持 (v7.5.0)"/> — 新增 fediverse:creator meta 标签，支持 Mastodon 等去中心化社交平台的创作者身份验证。
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="🌍" FontWeight="SemiBold"/> <Run Text="更多语言包 (v7.4.0)"/> — 新增丹麦语以及 RTL（阿拉伯语等从右到左书写）语言文件。
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="{DynamicResource DashboardBugFixTitle}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                • 站内搜索：修复含特殊 JSON 字符的文章导致搜索功能崩溃的问题；恢复带 description 文章的全文搜索能力。
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                • LQIP 图片预加载：修复主页缩略图与文章页封面不一致的问题，恢复模糊渐变动画效果。
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                • 侧边栏：修复未配置的社交图标的显示异常；修正 GoatCounter 数据提取不准确的问题。
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                • 标题多语言 (v7.5.0)：修复某些页面标题未能调用本地化语言包的问题。
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </ui:CardExpander>

                <!-- 统计卡片区 -->
                <UniformGrid Columns="3" Margin="0,0,0,24">
                    <ui:CardAction Padding="20" Margin="0,0,16,0" IsChevronVisible="True" Cursor="Hand" Click="PostCountCard_Click" ToolTip="点击查看全部文章">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Document24" FontSize="28" Margin="0,0,0,12" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{DynamicResource DashboardTotalPosts}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="PostCountText" Text="--" FontSize="32" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </ui:CardAction>

                    <ui:CardAction Padding="20" Margin="0,0,16,0" IsChevronVisible="True" Cursor="Hand" Click="CategoryCountCard_Click" ToolTip="点击浏览分类">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Folder24" FontSize="28" Margin="0,0,0,12" Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                            <TextBlock Text="{DynamicResource DashboardTotalCategories}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="CategoryCountText" Text="--" FontSize="32" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </ui:CardAction>

                    <ui:CardAction Padding="20" Margin="0,0,0,0" IsChevronVisible="True" Cursor="Hand" Click="TagCountCard_Click" ToolTip="点击浏览标签">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Tag24" FontSize="28" Margin="0,0,0,12" Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                            <TextBlock Text="{DynamicResource DashboardTotalTags}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TagCountText" Text="--" FontSize="32" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </ui:CardAction>
                </UniformGrid>

                <!-- 分类/标签展开区 -->
                <Border x:Name="DetailPanel" Visibility="Collapsed" Margin="0,0,0,24"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock x:Name="DetailPanelTitle" Text="" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ui:Button Content="{DynamicResource DashboardBtnExpandAll}" Style="{StaticResource LiftedUiButtonStyle}" Margin="0,0,8,0" Click="ExpandAllDetail_Click"/>
                                <ui:Button Content="{DynamicResource DashboardBtnCollapseAll}" Style="{StaticResource LiftedUiButtonStyle}" Margin="0,0,8,0" Click="CollapseAllDetail_Click"/>
                                <ui:Button Icon="{ui:SymbolIcon Symbol=Dismiss24}" Style="{StaticResource LiftedUiButtonStyle}" Background="Transparent" BorderThickness="0"
                                           Click="CloseDetailPanel_Click" ToolTip="关闭" Padding="4"/>
                            </StackPanel>
                        </DockPanel>
                        <ItemsControl x:Name="DetailItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Header="{Binding Header}" IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Margin="0,4,0,4" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Padding="8" Background="Transparent" BorderThickness="0">
                                        <StackPanel Margin="16,4,0,4">
                                            <!-- Sub-category expanders (Children) -->
                                            <ItemsControl ItemsSource="{Binding Children}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Expander Header="{Binding Header}" IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Margin="0,4,0,4" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Padding="6" Background="Transparent" BorderThickness="0">
                                                            <ItemsControl ItemsSource="{Binding Posts}" Margin="24,4,0,4">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding}" Margin="0,4" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Expander>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- Direct posts (no sub-category) -->
                                            <ItemsControl ItemsSource="{Binding Posts}" Margin="8,4,0,4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Margin="0,4" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 快捷操作区 -->
                <TextBlock Text="{DynamicResource DashboardQuickActions}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,12" Background="Transparent">
                    <ui:Button Content="{DynamicResource DashboardBtnWriteNew}" Style="{StaticResource LiftedUiButtonStyle}" Appearance="Primary" Click="WriteNewPost_Click" Icon="{ui:SymbolIcon Symbol=Edit24}" Margin="0,0,16,0" Padding="16,8"/>
                    <ui:Button Content="{DynamicResource DashboardBtnViewSite}" Style="{StaticResource LiftedUiButtonStyle}" Click="ViewLiveSite_Click" Icon="{ui:SymbolIcon Symbol=Globe24}" Margin="0,0,16,0" Padding="16,8"/>
                    <ui:Button x:Name="SyncButton" Style="{StaticResource LiftedUiButtonStyle}" Content="{DynamicResource DashboardBtnSyncCloud}" Click="SyncButton_Click" Icon="{ui:SymbolIcon Symbol=ArrowSync24}" Padding="16,8"/>
                </WrapPanel>
                <ui:InfoBar x:Name="SyncInfoBar" IsOpen="False" Message="" Severity="Informational" Margin="0,0,0,16" />

                <!-- 全部文章时间线 -->
                <TextBlock Text="{DynamicResource DashboardTimelineTitle}" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,16"/>
                <ItemsControl x:Name="TimelineList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,0" Padding="12,10" Cursor="Hand"
                                    Background="Transparent" MouseLeftButtonUp="TimelineItem_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel>
                                    <TextBlock Text="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" Width="90"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="13"
                                               VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                    <TextBlock Text="{Binding CategoryDisplay}" Width="140"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                                               VerticalAlignment="Center" DockPanel.Dock="Left" Margin="8,0"/>
                                    <TextBlock Text="{Binding Title}" FontSize="14" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
