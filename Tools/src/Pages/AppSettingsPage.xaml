<Page x:Class="BlogTools.AppSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:BlogTools.Helpers"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Title="{DynamicResource NavAppSettings}">
    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8" />
                    <ThicknessAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Margin" From="0,40,0,0" To="16" Duration="0:0:0.8">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>
    <Grid Margin="16" x:Name="MainContent" Opacity="0" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <ui:SymbolIcon Symbol="Settings24" FontSize="32" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
            <StackPanel>
                <TextBlock Text="{DynamicResource AppSettingsTitle}" FontSize="24" FontWeight="SemiBold"/>
                <TextBlock Text="{DynamicResource AppSettingsSub}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <ui:InfoBar Grid.Row="1" x:Name="StatusInfo" IsOpen="False" Message="" Severity="Success" Margin="0,0,0,8" />

        <ScrollViewer Grid.Row="2"
                      x:Name="PageScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      Background="Transparent"
                      Focusable="False"
                      PreviewMouseWheel="PageScrollViewer_PreviewMouseWheel"
                      helpers:SmoothScrollHelper.SmoothingEnabled="True">
            <StackPanel Background="Transparent" Margin="0,0,16,0">
                <TextBlock Text="{DynamicResource SettingsSecWorkspace}" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ui:CardControl Margin="0,0,0,24" Icon="{ui:SymbolIcon Symbol=FolderOpen24}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource SettingsLabelBlogPath}" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock x:Name="CurrentPathBlock" Text="C:\..." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:Button Content="{DynamicResource SettingsBtnChangePath}" Style="{StaticResource LiftedUiButtonStyle}" Click="ChangeBlogPath_Click" />
                </ui:CardControl>

                <TextBlock Text="{DynamicResource SettingsSecDrafting}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <StackPanel Margin="0,0,0,24">
                    <ui:CardControl Margin="0,0,0,4" Icon="{ui:SymbolIcon Symbol=Document24}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsLabelRememberMetadata}" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="{DynamicResource SettingsDescRememberMetadata}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch x:Name="RememberMetadataToggle" Checked="RememberMetadata_Checked" Unchecked="RememberMetadata_Unchecked" />
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,4" Icon="{ui:SymbolIcon Symbol=Document24}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsLabelKeepToolboxToolWhenPinned}" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="{DynamicResource SettingsDescKeepToolboxToolWhenPinned}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch x:Name="KeepToolboxToolWhenPinnedToggle" Checked="KeepToolboxToolWhenPinned_Checked" Unchecked="KeepToolboxToolWhenPinned_Unchecked" />
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,0" Icon="{ui:SymbolIcon Symbol=Clock24}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsLabelAutoUpdateMod}" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="{DynamicResource SettingsDescAutoUpdateMod}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch x:Name="AutoUpdateModifiedTimeToggle" Checked="AutoUpdateModifiedTime_Checked" Unchecked="AutoUpdateModifiedTime_Unchecked" />
                    </ui:CardControl>
                </StackPanel>

                <TextBlock Text="{DynamicResource SettingsSecAppearance}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <StackPanel Margin="0,0,0,24">
                    <ui:CardControl Margin="0,0,0,4" Icon="{ui:SymbolIcon Symbol=WeatherMoon24}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsLabelDarkMode}" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="{DynamicResource SettingsDescDarkMode}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ComboBox x:Name="ThemeModeComboBox" Width="200" SelectionChanged="ThemeModeComboBox_SelectionChanged">
                            <ComboBoxItem Content="{DynamicResource SettingsThemeModeAuto}" Tag="Auto"/>
                            <ComboBoxItem Content="{DynamicResource SettingsThemeModeDark}" Tag="Dark"/>
                            <ComboBoxItem Content="{DynamicResource SettingsThemeModeLight}" Tag="Light"/>
                        </ComboBox>
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,4" Icon="{ui:SymbolIcon Symbol=Globe24}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsLabelLanguage}" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="{DynamicResource SettingsDescLanguage}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ComboBox x:Name="LanguageComboBox" Width="200" SelectionChanged="LanguageComboBox_SelectionChanged">
                            <ComboBoxItem Content="跟随系统 (Auto)" Tag="Auto"/>
                            <ComboBoxItem Content="简体中文" Tag="zh-CN"/>
                            <ComboBoxItem Content="English" Tag="en-US"/>
                        </ComboBox>
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,0" Icon="{ui:SymbolIcon Symbol=TextFont24}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsLabelFont}" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="{DynamicResource SettingsDescFont}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ComboBox x:Name="FontComboBox"
                                  Width="200"
                                  MaxDropDownHeight="300"
                                  IsTextSearchEnabled="True"
                                  SelectionChanged="FontComboBox_SelectionChanged"
                                  helpers:SmoothScrollHelper.SmoothingEnabled="True"
                                  ScrollViewer.CanContentScroll="False"/>
                    </ui:CardControl>
                </StackPanel>

                <TextBlock Text="{DynamicResource SettingsSecUpdates}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <StackPanel Margin="0,0,0,24">
                    <ui:CardControl Margin="0,0,0,4" Icon="{ui:SymbolIcon Symbol=ArrowDownload24}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsLabelCheckUpdate}" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock x:Name="VersionBlock" Text="..." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ui:Button x:Name="CheckUpdateButton" Style="{StaticResource LiftedUiButtonStyle}" Content="{DynamicResource SettingsBtnCheckUpdate}" Click="CheckUpdate_Click" />
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,4" Icon="{ui:SymbolIcon Symbol=ArrowSync24}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsLabelSilentUpdate}" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="{DynamicResource SettingsDescSilentUpdate}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch x:Name="SilentUpdateToggle" Checked="SilentUpdate_Checked" Unchecked="SilentUpdate_Unchecked" />
                    </ui:CardControl>

                    <ui:CardAction Margin="0,0,0,4" Icon="{ui:SymbolIcon Symbol=Star24}" Command="{Binding Path=.}" Click="OpenGithubStar_Click">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource SettingsLabelStar}" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="{DynamicResource SettingsDescStar}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                    </ui:CardAction>

                    <Border x:Name="ProgressPanel" Visibility="Collapsed"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock x:Name="ProgressText" Text="{DynamicResource SettingsMsgProgressPreparing}" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                            <ProgressBar x:Name="DownloadProgress" Minimum="0" Maximum="100" Value="0" Height="6" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
