<Page x:Class="BlogTools.EditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:helpers="clr-namespace:BlogTools.Helpers"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      ScrollViewer.VerticalScrollBarVisibility="Disabled"
      helpers:SmoothScrollHelper.SmoothingEnabled="True"
      Title="{DynamicResource NavEditor}">

    <Grid x:Name="RootGrid"
          Margin="16,16,16,16"
          Focusable="True">
        <Grid.Resources>
            <Style x:Key="EditorToolButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,8,8" />
                <Setter Property="Width" Value="46" />
                <Setter Property="Height" Value="46" />
                <Setter Property="MinWidth" Value="46" />
                <Setter Property="MinHeight" Value="46" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="ToolTipService.InitialShowDelay" Value="220" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ToolButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ToolButtonBorder" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                    <Setter TargetName="ToolButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ToolButtonBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    <Setter TargetName="ToolButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="ToolButtonBorder" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="EditorSideToolButtonStyle" TargetType="Button" BasedOn="{StaticResource EditorToolButtonStyle}">
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>
            <Style x:Key="EditorToolIconStyle" TargetType="ui:SymbolIcon">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontSize" Value="20" />
            </Style>
            <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="Margin" Value="0,0,8,0" />
                <Setter Property="Height" Value="40" />
                <Setter Property="MinHeight" Value="40" />
                <Setter Property="MinWidth" Value="44" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="ToolTipService.InitialShowDelay" Value="220" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="HeaderActionBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HeaderActionBorder" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                    <Setter TargetName="HeaderActionBorder" Property="BorderBrush" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="HeaderActionBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    <Setter TargetName="HeaderActionBorder" Property="BorderBrush" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="HeaderActionBorder" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="HeaderPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderActionButtonStyle}">
                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
            </Style>
            <Style x:Key="HeaderIconButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderActionButtonStyle}">
                <Setter Property="Width" Value="40" />
                <Setter Property="MinWidth" Value="40" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
            </Style>
            <DataTemplate x:Key="EditorToolGlyphTemplate">
                <Grid Width="24" Height="24">
                    <ui:SymbolIcon x:Name="ToolSymbol"
                                   Symbol="{Binding Symbol}"
                                   FontSize="{Binding SymbolFontSize}"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}"
                                   Style="{StaticResource EditorToolIconStyle}" />
                    <TextBlock x:Name="ToolLabel"
                               Visibility="Collapsed"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}" />
                    <Grid x:Name="DividerGlyph"
                          Visibility="Collapsed"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Width="18"
                          Height="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="1"
                                Height="2"
                                CornerRadius="1"
                                Background="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}" />
                    </Grid>
                </Grid>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding Id}" Value="h1">
                        <Setter TargetName="ToolSymbol" Property="Visibility" Value="Collapsed" />
                        <Setter TargetName="ToolLabel" Property="Visibility" Value="Visible" />
                        <Setter TargetName="ToolLabel" Property="Text" Value="H1" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Id}" Value="h2">
                        <Setter TargetName="ToolSymbol" Property="Visibility" Value="Collapsed" />
                        <Setter TargetName="ToolLabel" Property="Visibility" Value="Visible" />
                        <Setter TargetName="ToolLabel" Property="Text" Value="H2" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Id}" Value="h3">
                        <Setter TargetName="ToolSymbol" Property="Visibility" Value="Collapsed" />
                        <Setter TargetName="ToolLabel" Property="Visibility" Value="Visible" />
                        <Setter TargetName="ToolLabel" Property="Text" Value="H3" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Id}" Value="h4">
                        <Setter TargetName="ToolSymbol" Property="Visibility" Value="Collapsed" />
                        <Setter TargetName="ToolLabel" Property="Visibility" Value="Visible" />
                        <Setter TargetName="ToolLabel" Property="Text" Value="H4" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Id}" Value="divider">
                        <Setter TargetName="ToolSymbol" Property="Visibility" Value="Collapsed" />
                        <Setter TargetName="DividerGlyph" Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:InfoBar Grid.Row="0"
                    x:Name="StatusInfo"
                    IsOpen="False"
                    Message=""
                    Severity="Success"
                    Margin="0,0,0,8"
                    Panel.ZIndex="10" />

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0"
                        x:Name="TitleBox"
                        PlaceholderText="{DynamicResource EditorTitleBoxPlaceholder}"
                        FontSize="18"
                        FontWeight="Bold"
                        Margin="0,0,16,0" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button x:Name="ViewModeButton"
                        Click="ViewModeButton_Click"
                        Style="{StaticResource HeaderActionButtonStyle}"
                        MinWidth="96"
                        ToolTip="{DynamicResource EditorViewModeLabel}">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="ViewModeContextMenu"
                                     Placement="Bottom">
                            <MenuItem x:Name="WriteOnlyMenuItem"
                                      Tag="WriteOnly"
                                      Header="{DynamicResource EditorViewModeWriteOnly}"
                                      IsCheckable="True"
                                      Click="ViewModeMenuItem_Click" />
                            <MenuItem x:Name="SplitMenuItem"
                                      Tag="Split"
                                      Header="{DynamicResource EditorViewModeSplit}"
                                      IsCheckable="True"
                                      Click="ViewModeMenuItem_Click" />
                            <MenuItem x:Name="PreviewOnlyMenuItem"
                                      Tag="PreviewOnly"
                                      Header="{DynamicResource EditorViewModePreviewOnly}"
                                      IsCheckable="True"
                                      Click="ViewModeMenuItem_Click" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ViewModeButtonText"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}" />
                        <TextBlock Text="▼"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"
                                   FontSize="10"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderActionButtonStyle}"
                        Click="SaveButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Save24"
                                       FontSize="16"
                                       Margin="0,0,6,0"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}" />
                        <TextBlock Text="{DynamicResource EditorBtnSaveDraft}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderPrimaryActionButtonStyle}"
                        Click="PublishButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Send24"
                                       FontSize="16"
                                       Margin="0,0,6,0"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}" />
                        <TextBlock Text="{DynamicResource EditorBtnPublish}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderIconButtonStyle}"
                        Click="NewPost_Click"
                        ToolTip="{DynamicResource EditorBtnClear}">
                    <ui:SymbolIcon Symbol="Delete24"
                                   FontSize="16"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}" />
                </Button>
            </StackPanel>
        </Grid>

        <Expander x:Name="MetadataExpander" Grid.Row="2" Header="{DynamicResource EditorExpanderMetadata}" IsExpanded="False" Margin="0,0,0,8" HorizontalAlignment="Stretch" Expanded="MetadataExpander_Expanded" Collapsed="MetadataExpander_Collapsed">
            <Grid Margin="12,12,12,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{DynamicResource EditorLabelPublishTime}" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <DatePicker x:Name="PublishDatePicker" Grid.Column="0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ComboBox x:Name="PublishHourBox" Width="75" Margin="0,0,4,0"/>
                        <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="PublishMinuteBox" Width="75" Margin="0,0,4,0"/>
                        <ui:Button Icon="{ui:SymbolIcon Symbol=Clock24}" Click="SetPublishNow_Click" ToolTip="{DynamicResource EditorBtnSetNow}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="{DynamicResource EditorLabelCategory}" VerticalAlignment="Center" Grid.Row="0" Grid.Column="3" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Margin="0,0,0,12">
                    <ComboBox x:Name="PrimaryCategoryBox" IsEditable="True" Width="100" Margin="0,0,8,0" Text="" />
                    <ComboBox x:Name="SecondaryCategoryBox" IsEditable="True" Width="100" Text="" />
                </StackPanel>

                <TextBlock Text="{DynamicResource EditorLabelModifyTime}" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <DatePicker x:Name="ModifyDatePicker" Grid.Column="0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ComboBox x:Name="ModifyHourBox" Width="75" Margin="0,0,4,0"/>
                        <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="ModifyMinuteBox" Width="75" Margin="0,0,4,0"/>
                        <ui:Button Icon="{ui:SymbolIcon Symbol=Clock24}" Click="SetModifyNow_Click" ToolTip="{DynamicResource EditorBtnSetNow}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="{DynamicResource EditorLabelTags}" VerticalAlignment="Center" Grid.Row="1" Grid.Column="3" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Border Grid.Row="1" Grid.Column="4" Margin="0,0,0,12" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="4,4,4,0" MinHeight="32" Cursor="IBeam" MouseDown="TagsBorder_MouseDown">
                    <WrapPanel VerticalAlignment="Center">
                        <ItemsControl x:Name="TagsItemsControl" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ui:Button Content="{Binding}" Icon="{ui:SymbolIcon Symbol=Dismiss12}" Margin="0,0,4,4" Appearance="Secondary" FontSize="12" Padding="8,2" MinHeight="24" Click="RemoveTag_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBox x:Name="TagInputBox" MinWidth="100" Margin="0,0,0,4" Padding="0,4,0,0" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" KeyDown="TagInputBox_KeyDown" LostFocus="TagInputBox_LostFocus"/>
                    </WrapPanel>
                </Border>

                <TextBlock Text="{DynamicResource EditorLabelAuthor}" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ui:TextBox x:Name="AuthorBox" PlaceholderText="{DynamicResource EditorLabelAuthorPlaceholder}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12"/>

                <TextBlock Text="{DynamicResource EditorLabelImage}" VerticalAlignment="Center" Grid.Row="2" Grid.Column="3" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ui:TextBox x:Name="ImageBox" PlaceholderText="/path/to/image.jpg" Grid.Row="2" Grid.Column="4" Margin="0,0,0,12"/>

                <TextBlock Text="{DynamicResource EditorLabelQuickFeatures}" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" Margin="0,0,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" Grid.Row="3" Grid.Column="1" Margin="0,0,0,0" VerticalAlignment="Center">
                    <ui:ToggleSwitch x:Name="MathSwitch" Content="{DynamicResource EditorToggleMath}" Margin="0,0,16,0" />
                    <ui:ToggleSwitch x:Name="TocSwitch" Content="{DynamicResource EditorToggleToc}" IsChecked="True" Margin="0,0,16,0" />
                    <ui:ToggleSwitch x:Name="PinSwitch" Content="{DynamicResource EditorTogglePin}" />
                </StackPanel>

                <TextBlock Text="{DynamicResource EditorLabelDescription}" VerticalAlignment="Top" Grid.Row="3" Grid.Column="3" Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ui:TextBox x:Name="DescriptionBox" PlaceholderText="{DynamicResource EditorDescriptionPlaceholder}" Grid.Row="3" Grid.Column="4" Margin="0,0,0,0" AcceptsReturn="True" MinHeight="40" TextWrapping="Wrap"/>
            </Grid>
        </Expander>

        <Grid x:Name="EditorWorkspaceGrid" Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="EditorColumn" Width="*" />
                <ColumnDefinition x:Name="SideToolsColumn" Width="88" />
                <ColumnDefinition x:Name="PreviewColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="EditorPane"
                    Grid.Column="0"
                    VerticalAlignment="Stretch"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    CornerRadius="8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="0,0,0,1"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="12,10,12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{DynamicResource EditorToolboxLabel}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                <ui:Button x:Name="ToolboxToggleButton"
                                           Grid.Column="1"
                                           Click="ToolboxToggleButton_Click"
                                           Appearance="Secondary"
                                           Padding="12,4"
                                           MinWidth="92"
                                           VerticalAlignment="Center"
                                           ToolTipService.InitialShowDelay="220"
                                           ToolTipService.Placement="Bottom">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ToolboxToggleGlyph"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="11" />
                                        <TextBlock x:Name="ToolboxToggleText"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </ui:Button>
                            </Grid>

                            <Border x:Name="ToolboxContentPanel"
                                    Grid.Row="1"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="12,10,12,6"
                                    RenderTransformOrigin="0.5,0.5"
                                    AllowDrop="True"
                                    DragOver="RibbonToolsHost_DragOver"
                                    DragLeave="RibbonToolsHost_DragLeave"
                                    Drop="RibbonToolsHost_Drop">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="RibbonToolsScaleTransform" ScaleX="1" ScaleY="1" />
                                </Border.RenderTransform>
                                <Grid x:Name="RibbonToolsHostGrid">
                                    <ItemsControl x:Name="RibbonToolsItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Click="ToolbarTool_Click"
                                                        PreviewMouseLeftButtonDown="ToolButton_PreviewMouseLeftButtonDown"
                                                        PreviewMouseMove="ToolButton_PreviewMouseMove"
                                                        PreviewMouseLeftButtonUp="ToolButton_PreviewMouseLeftButtonUp"
                                                        Style="{StaticResource EditorToolButtonStyle}"
                                                        Content="{Binding}"
                                                        ContentTemplate="{StaticResource EditorToolGlyphTemplate}"
                                                        ToolTip="{Binding ToolTipText}">
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border x:Name="RibbonDropCue"
                                            IsHitTestVisible="False"
                                            Opacity="0"
                                            CornerRadius="8"
                                            BorderThickness="1"
                                            BorderBrush="#660078D4"
                                            Background="#140078D4" />
                                    <Canvas IsHitTestVisible="False">
                                        <Border x:Name="RibbonInsertionIndicator"
                                                Width="4"
                                                Height="32"
                                                Opacity="0"
                                                CornerRadius="2"
                                                Background="{DynamicResource AccentTextFillColorPrimaryBrush}">
                                            <Border.RenderTransform>
                                                <TranslateTransform x:Name="RibbonInsertionTransform" />
                                            </Border.RenderTransform>
                                        </Border>
                                    </Canvas>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <wv2:WebView2 x:Name="EditorWebView" Grid.Row="1" />
                </Grid>
            </Border>

            <Border x:Name="SideToolsPanel"
                    Grid.Column="1"
                    Margin="3,0"
                    Padding="4,12"
                    VerticalAlignment="Stretch"
                    Cursor="SizeWE"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    CornerRadius="14"
                    RenderTransformOrigin="0.5,0.5"
                    ToolTip="{DynamicResource EditorViewModeDragTip}"
                    AllowDrop="True"
                    PreviewMouseLeftButtonDown="SideToolsPanel_PreviewMouseLeftButtonDown"
                    PreviewMouseMove="SideToolsPanel_PreviewMouseMove"
                    PreviewMouseLeftButtonUp="SideToolsPanel_PreviewMouseLeftButtonUp"
                    LostMouseCapture="SideToolsPanel_LostMouseCapture"
                    DragOver="SideToolsHost_DragOver"
                    DragLeave="SideToolsHost_DragLeave"
                    Drop="SideToolsHost_Drop">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="SideToolsScaleTransform" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Grid x:Name="SideToolsHostGrid">
                    <ItemsControl x:Name="SideToolsItemsControl"
                                  VerticalAlignment="Top"
                                  HorizontalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="ToolbarTool_Click"
                                        PreviewMouseLeftButtonDown="ToolButton_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="ToolButton_PreviewMouseMove"
                                        PreviewMouseLeftButtonUp="ToolButton_PreviewMouseLeftButtonUp"
                                        Style="{StaticResource EditorSideToolButtonStyle}"
                                        Content="{Binding}"
                                        ContentTemplate="{StaticResource EditorToolGlyphTemplate}"
                                        ToolTip="{Binding ToolTipText}">
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border x:Name="SideDropCue"
                            IsHitTestVisible="False"
                            Opacity="0"
                            CornerRadius="10"
                            BorderThickness="1"
                            BorderBrush="#660078D4"
                            Background="#140078D4" />
                    <Canvas IsHitTestVisible="False">
                        <Border x:Name="SideInsertionIndicator"
                                Width="42"
                                Height="4"
                                Opacity="0"
                                CornerRadius="2"
                                Background="{DynamicResource AccentTextFillColorPrimaryBrush}">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="SideInsertionTransform" />
                            </Border.RenderTransform>
                        </Border>
                    </Canvas>
                </Grid>
            </Border>

            <Border x:Name="PreviewPane"
                    Grid.Column="2"
                    VerticalAlignment="Stretch"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    CornerRadius="8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    ClipToBounds="True">
                <wv2:WebView2 x:Name="PreviewWebView" />
            </Border>
        </Grid>
