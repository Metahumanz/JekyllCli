<ui:FluentWindow x:Class="BlogTools.InsertLinkDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{DynamicResource EditorDialogLinkTitle}"
                 Width="480"
                 SizeToContent="Height"
                 MinHeight="320"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource EditorDialogLinkTitle}" />

        <StackPanel Grid.Row="1" Margin="24,20,24,20">
            <TextBlock Text="{DynamicResource EditorDialogLinkDescription}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,16"/>

            <TextBlock Text="{DynamicResource EditorDialogLinkTextLabel}"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <ui:TextBox x:Name="LinkTextBox"
                        PlaceholderText="{DynamicResource EditorDialogLinkTextPlaceholder}"
                        Margin="0,0,0,14"
                        TextChanged="Input_TextChanged"/>

            <TextBlock Text="{DynamicResource EditorDialogLinkUrlLabel}"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <ui:TextBox x:Name="LinkUrlBox"
                        PlaceholderText="{DynamicResource EditorDialogLinkUrlPlaceholder}"
                        Margin="0,0,0,14"
                        TextChanged="Input_TextChanged"/>

            <ui:ToggleSwitch x:Name="OpenInNewTabSwitch"
                             Content="{DynamicResource EditorDialogLinkOpenNewTab}" />
        </StackPanel>

        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="{DynamicResource CommonCancel}"
                           Appearance="Transparent"
                           Margin="0,0,10,0"
                           Click="Cancel_Click"/>
                <ui:Button x:Name="InsertButton"
                           Content="{DynamicResource EditorDialogLinkInsert}"
                           Appearance="Primary"
                           IsEnabled="False"
                           Click="Insert_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
