<ui:FluentWindow x:Class="BlogTools.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource SetupTitle}" Width="600"
        SizeToContent="Height"
        MinHeight="400" MaxHeight="720"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource SetupTitle}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,24">
                <TextBlock Text="{DynamicResource SetupTitle}" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,16"/>
                <TextBlock Text="{DynamicResource SetupSubtitle}" Margin="0,0,0,10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                
                <TextBlock Text="{DynamicResource SetupStep1Title}" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="BlogPathBox" IsReadOnly="True" Margin="0,0,10,0" PlaceholderText="..."/>
                    <ui:Button Grid.Column="1" Content="{DynamicResource SetupBtnSelectFolder}" Click="Browse_Click" Appearance="Secondary"/>
                </Grid>

                <!-- 零基础开始区块 -->
                <Expander x:Name="CreateBlogExpander" Header="{DynamicResource SetupBtnUseTemplate}" Margin="0,0,0,16" IsExpanded="False">
                    <StackPanel Margin="10">
                        <TextBlock Text="{DynamicResource SetupStep1Desc}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,10" FontSize="12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button x:Name="UseBundleBtn" Grid.Column="0" Content="{DynamicResource SetupBtnUseBundle}" Click="UseBundle_Click" HorizontalAlignment="Stretch" Padding="0,8"/>
                            <ui:Button x:Name="CloneRemoteBtn" Grid.Column="2" Content="{DynamicResource SetupBtnFromGithub}" Click="CloneRemote_Click" HorizontalAlignment="Stretch" Padding="0,8"/>
                        </Grid>
                        <ProgressBar x:Name="InitProgressBar" IsIndeterminate="True" Visibility="Collapsed" Margin="0,10,0,0" />
                        <TextBlock x:Name="InitStatusText" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" Margin="0,5,0,0" Visibility="Collapsed" FontSize="12" />
                    </StackPanel>
                </Expander>

                <TextBlock Text="{DynamicResource SetupStep2Title}" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <ComboBox x:Name="LanguageBox" SelectedIndex="0" HorizontalAlignment="Stretch" Margin="0,0,0,16">
                    <ComboBoxItem Content="中文 (zh-CN)" Tag="zh-CN"/>
                    <ComboBoxItem Content="English (en)" Tag="en"/>
                </ComboBox>
                
                <ui:InfoBar x:Name="ErrorBar" IsOpen="False" Severity="Error" Title="{DynamicResource CommonError}" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="{DynamicResource SetupBtnCancel}" Click="Cancel_Click" Margin="0,0,10,0" Appearance="Transparent"/>
                <ui:Button x:Name="FinishBtn" Content="{DynamicResource SetupBtnComplete}" Click="Finish_Click" Appearance="Primary"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
