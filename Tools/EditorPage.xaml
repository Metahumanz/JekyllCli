<Page x:Class="BlogTools.EditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:helpers="clr-namespace:BlogTools.Helpers"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      ScrollViewer.VerticalScrollBarVisibility="Disabled"
      helpers:SmoothScrollHelper.SmoothingEnabled="True"
      Title="{DynamicResource NavEditor}">

    <Grid x:Name="RootGrid" Margin="16,16,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:InfoBar Grid.Row="0" x:Name="StatusInfo" IsOpen="False" Message="" Severity="Success" Margin="0,0,0,8" Panel.ZIndex="10"/>

        <!-- 标题行与操作区 -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" x:Name="TitleBox" PlaceholderText="{DynamicResource EditorTitleBoxPlaceholder}" FontSize="18" FontWeight="Bold" Margin="0,0,16,0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Content="{DynamicResource EditorBtnSaveDraft}" Click="SaveButton_Click" Icon="{ui:SymbolIcon Symbol=Save24}" Margin="0,0,8,0" />
                <ui:Button Content="{DynamicResource EditorBtnPublish}" Appearance="Primary" Click="PublishButton_Click" Icon="{ui:SymbolIcon Symbol=Send24}" Margin="0,0,8,0" />
                <ui:Button Click="NewPost_Click" Icon="{ui:SymbolIcon Symbol=Delete24}" ToolTip="{DynamicResource EditorBtnClear}" />
            </StackPanel>
        </Grid>

        <!-- 元数据区 -->
        <Expander x:Name="MetadataExpander" Grid.Row="2" Header="{DynamicResource EditorExpanderMetadata}" IsExpanded="False" Margin="0,0,0,8" HorizontalAlignment="Stretch" Expanded="MetadataExpander_Expanded" Collapsed="MetadataExpander_Collapsed">
            <Grid Margin="12,12,12,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Row 0 -->
                <TextBlock Text="{DynamicResource EditorLabelPublishTime}" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <DatePicker x:Name="PublishDatePicker" Grid.Column="0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ComboBox x:Name="PublishHourBox" Width="75" Margin="0,0,4,0"/>
                        <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="PublishMinuteBox" Width="75" Margin="0,0,4,0"/>
                        <ui:Button Icon="{ui:SymbolIcon Symbol=Clock24}" Click="SetPublishNow_Click" ToolTip="{DynamicResource EditorBtnSetNow}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="{DynamicResource EditorLabelCategory}" VerticalAlignment="Center" Grid.Row="0" Grid.Column="3" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Margin="0,0,0,12">
                    <ComboBox x:Name="PrimaryCategoryBox" IsEditable="True" Width="100" Margin="0,0,8,0" ToolTip="一级分类" Text="" />
                    <ComboBox x:Name="SecondaryCategoryBox" IsEditable="True" Width="100" ToolTip="二级分类" Text="" />
                </StackPanel>

                <!-- Row 1 -->
                <TextBlock Text="{DynamicResource EditorLabelModifyTime}" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <DatePicker x:Name="ModifyDatePicker" Grid.Column="0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ComboBox x:Name="ModifyHourBox" Width="75" Margin="0,0,4,0"/>
                        <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="ModifyMinuteBox" Width="75" Margin="0,0,4,0"/>
                        <ui:Button Icon="{ui:SymbolIcon Symbol=Clock24}" Click="SetModifyNow_Click" ToolTip="{DynamicResource EditorBtnSetNow}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="{DynamicResource EditorLabelTags}" VerticalAlignment="Center" Grid.Row="1" Grid.Column="3" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Border Grid.Row="1" Grid.Column="4" Margin="0,0,0,12" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="4,4,4,0" MinHeight="32" Cursor="IBeam" MouseDown="TagsBorder_MouseDown">
                    <WrapPanel VerticalAlignment="Center">
                        <ItemsControl x:Name="TagsItemsControl" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ui:Button Content="{Binding}" Icon="{ui:SymbolIcon Symbol=Dismiss12}" Margin="0,0,4,4" Appearance="Secondary" FontSize="12" Padding="8,2" MinHeight="24" Click="RemoveTag_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBox x:Name="TagInputBox" MinWidth="100" Margin="0,0,0,4" Padding="0,4,0,0" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" KeyDown="TagInputBox_KeyDown" LostFocus="TagInputBox_LostFocus"/>
                    </WrapPanel>
                </Border>

                <!-- Row 2 -->
                <TextBlock Text="{DynamicResource EditorLabelAuthor}" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ui:TextBox x:Name="AuthorBox" PlaceholderText="{DynamicResource EditorLabelAuthorPlaceholder}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12"/>

                <TextBlock Text="{DynamicResource EditorLabelImage}" VerticalAlignment="Center" Grid.Row="2" Grid.Column="3" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ui:TextBox x:Name="ImageBox" PlaceholderText="/path/to/image.jpg" Grid.Row="2" Grid.Column="4" Margin="0,0,0,12"/>

                <!-- Row 3 -->
                <TextBlock Text="{DynamicResource EditorLabelQuickFeatures}" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" Margin="0,0,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" Grid.Row="3" Grid.Column="1" Margin="0,0,0,0" VerticalAlignment="Center">
                    <ui:ToggleSwitch x:Name="MathSwitch" Content="{DynamicResource EditorToggleMath}" Margin="0,0,16,0" />
                    <ui:ToggleSwitch x:Name="TocSwitch" Content="{DynamicResource EditorToggleToc}" IsChecked="True" Margin="0,0,16,0" />
                    <ui:ToggleSwitch x:Name="PinSwitch" Content="{DynamicResource EditorTogglePin}" />
                </StackPanel>

                <TextBlock Text="{DynamicResource EditorLabelDescription}" VerticalAlignment="Top" Grid.Row="3" Grid.Column="3" Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ui:TextBox x:Name="DescriptionBox" PlaceholderText="{DynamicResource EditorDescriptionPlaceholder}" Grid.Row="3" Grid.Column="4" Margin="0,0,0,0" AcceptsReturn="True" MinHeight="40" TextWrapping="Wrap"/>

            </Grid>
        </Expander>

        <!-- 编辑区 + 同步按钮 + 预览区 -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：WebView2 编辑框 (自带 WebKit 滚动条) -->
            <Border Grid.Column="0"
                    VerticalAlignment="Stretch"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    CornerRadius="8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    ClipToBounds="True">
                <wv2:WebView2 x:Name="EditorWebView" />
            </Border>

            <!-- 中间：同步滚动按钮与图片工具 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                <ui:Button x:Name="InsertImageBtn" Click="InsertImage_Click"
                           ToolTip="上传并插入本地图片 (Alt+I)" Padding="6" Margin="0,0,0,16" Appearance="Primary">
                    <ui:SymbolIcon Symbol="Image24" FontSize="16"/>
                </ui:Button>

                <ui:Button x:Name="SyncToPreviewBtn" Click="SyncEditorToPreview_Click"
                           ToolTip="将预览同步到编辑位置" Padding="6" Margin="0,0,0,8">
                    <ui:SymbolIcon Symbol="ArrowRight24" FontSize="16"/>
                </ui:Button>
                <ui:Button x:Name="SyncToEditorBtn" Click="SyncPreviewToEditor_Click"
                           ToolTip="将编辑同步到预览位置" Padding="6">
                    <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="16"/>
                </ui:Button>
            </StackPanel>

            <!-- 右侧：WebView2 预览 (自带滚动) -->
            <Border Grid.Column="2"
                    VerticalAlignment="Stretch"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    CornerRadius="8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    ClipToBounds="True">
                <wv2:WebView2 x:Name="PreviewWebView" />
            </Border>
        </Grid>
    </Grid>
</Page>
