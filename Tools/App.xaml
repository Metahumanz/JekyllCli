<Application x:Class="BlogTools.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <!-- Default Language Dictionary -->
                <ResourceDictionary Source="pack://application:,,,/src/Resources/Languages/zh-CN.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <CornerRadius x:Key="AppButtonCornerRadius">10</CornerRadius>
            <CornerRadius x:Key="AppCardCornerRadius">14</CornerRadius>
            <CornerRadius x:Key="AppCompactCardCornerRadius">12</CornerRadius>

            <Style x:Key="RoundedUiButtonBaseStyle" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="CornerRadius" Value="{StaticResource AppButtonCornerRadius}" />
            </Style>

            <Style x:Key="RoundedCardControlStyle" TargetType="{x:Type ui:CardControl}" BasedOn="{StaticResource {x:Type ui:CardControl}}">
                <Setter Property="CornerRadius" Value="{StaticResource AppCardCornerRadius}" />
            </Style>

            <Style x:Key="RoundedCardExpanderStyle" TargetType="{x:Type ui:CardExpander}" BasedOn="{StaticResource {x:Type ui:CardExpander}}">
                <Setter Property="CornerRadius" Value="{StaticResource AppCardCornerRadius}" />
            </Style>

            <Style x:Key="LiftedUiButtonStyle" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource RoundedUiButtonBaseStyle}">
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                            <TranslateTransform Y="0" />
                        </TransformGroup>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1.03" ScaleY="1.03" />
                                    <TranslateTransform Y="-1" />
                                </TransformGroup>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="18"
                                                  Direction="270"
                                                  ShadowDepth="4"
                                                  Color="Black"
                                                  Opacity="0.18" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                    <TranslateTransform Y="0" />
                                </TransformGroup>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="14"
                                                  Direction="270"
                                                  ShadowDepth="3"
                                                  Color="Black"
                                                  Opacity="0.08" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.6" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="LiftedButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                            <TranslateTransform Y="0" />
                        </TransformGroup>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1.03" ScaleY="1.03" />
                                    <TranslateTransform Y="-1" />
                                </TransformGroup>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="18"
                                                  Direction="270"
                                                  ShadowDepth="4"
                                                  Color="Black"
                                                  Opacity="0.18" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                    <TranslateTransform Y="0" />
                                </TransformGroup>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="14"
                                                  Direction="270"
                                                  ShadowDepth="3"
                                                  Color="Black"
                                                  Opacity="0.08" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.6" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
